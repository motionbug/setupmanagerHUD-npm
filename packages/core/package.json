{
  "name": "@motionbug/setupmanagerhud-core",
  "version": "1.1.1",
  "description": "Real-time webhook dashboard for Setup Manager - deploy to Cloudflare Workers",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/motionbug/setupmanagerhud.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/motionbug/setupmanagerhud#readme",
  "bugs": {
    "url": "https://github.com/motionbug/setupmanagerhud/issues"
  },
  "private": false,
  "type": "module",
  "main": "./dist-worker/index.js",
  "types": "./dist-worker/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist-worker/index.js",
      "types": "./dist-worker/index.d.ts"
    }
  },
  "files": [
    "dist",
    "dist-worker",
    "dist-scripts",
    "migrations",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build:ui": "vite build",
    "build:worker": "tsup",
    "build:scripts": "shx mkdir -p dist-scripts && shx cp scripts/sync-migrations.js dist-scripts/",
    "build": "npm run build:ui && npm run build:worker && npm run build:scripts",
    "prepublishOnly": "npm run build",
    "dev": "vite dev",
    "dev:worker": "wrangler dev",
    "typecheck": "tsc --noEmit",
    "test": "npm run build && vitest run",
    "test:components": "vitest run --config vitest.config.components.ts",
    "test:all": "npm run test && npm run test:components",
    "test:watch": "npm run build && vitest"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "cloudflare": {
    "bindings": {
      "DB": {
        "description": "D1 database used to store Setup Manager webhook events, dashboard history, stats, and filters."
      },
      "WEBHOOK_TOKEN": {
        "description": "Required shared secret for Setup Manager webhook POSTs. Enter a long random value, save it securely, and configure the exact same value in Setup Manager. Do not leave blank."
      }
    }
  },
  "dependencies": {
    "@fontsource-variable/figtree": "^5.2.10",
    "@hugeicons/core-free-icons": "^3.1.1",
    "@hugeicons/react": "^1.1.4",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.7.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.14.7",
    "@cloudflare/workers-types": "^4.20241127.0",
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.2.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "jsdom": "^29.1.1",
    "shx": "^0.4.0",
    "tailwindcss": "^4.0.0",
    "tsup": "^8.5.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.3.3",
    "vite": "^6.0.0",
    "vitest": "^4.1.4",
    "wrangler": "^4.61.0"
  }
}
